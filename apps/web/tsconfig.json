{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@zen-repo/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.vue"
  ],
  "exclude": ["node_modules", "dist"]
}
